# Konfigurasi Server
PORT=5063
NODE_ENV=development

# Konfigurasi MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=aris
DB_PASSWORD=Aris@022805
DB_NAME=penting_db

# JWT Secret (ganti dengan string random yang panjang)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h

# CORS - URL frontend Next.js
FRONTEND_URL=http://localhost:3000
